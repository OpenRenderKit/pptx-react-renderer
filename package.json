{
  "name": "pptx-react-renderer",
  "version": "0.1.0",
  "description": "Browser-first PPTX to HTML renderer with a React-friendly API.",
  "author": "Sidhaarth Krishnan",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenRenderKit/pptx-react-renderer.git"
  },
  "homepage": "https://github.com/OpenRenderKit/pptx-react-renderer#readme",
  "bugs": {
    "url": "https://github.com/OpenRenderKit/pptx-react-renderer/issues"
  },
  "keywords": [
    "pptx",
    "powerpoint",
    "presentation",
    "react",
    "renderer",
    "slides",
    "html",
    "parser",
    "browser"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "browser:bundle-harness": "esbuild test/browser/harness/runner.js --bundle --platform=browser --format=esm --outfile=test/browser/harness/bundle.js",
    "clean": "rm -rf dist coverage",
    "fixtures:generate": "node scripts/generate-test-fixtures.mjs",
    "fixtures:sanitize-complex": "node scripts/sanitize-complex-fixture.mjs",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:browser": "pnpm run build && pnpm run browser:bundle-harness && playwright test",
    "verify": "pnpm run typecheck && pnpm run build && pnpm run test",
    "pack:check": "pnpm pack --dry-run",
    "prepublishOnly": "pnpm run clean && pnpm run verify"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.5.2",
    "esbuild": "^0.27.0",
    "jsdom": "^27.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@10.30.3"
}
